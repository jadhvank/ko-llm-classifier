{
  "manifest_version": 3,
  "name": "한국어 AI 텍스트 판별 (신호등)",
  "description": "페이지 본문을 Readability로 추출해 한국어 AI 작성 여부를 아이콘 신호등으로 표시합니다. 분석은 브라우저 안에서만 수행되며 텍스트가 외부로 전송되지 않습니다.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "AI 텍스트 판별 — 클릭하면 분석 + 상세",
    "default_icon": {
      "16": "icons/tl-gray-16.png",
      "32": "icons/tl-gray-32.png",
      "48": "icons/tl-gray-48.png",
      "128": "icons/tl-gray-128.png"
    }
  },
  "icons": {
    "16": "icons/tl-gray-16.png",
    "32": "icons/tl-gray-32.png",
    "48": "icons/tl-gray-48.png",
    "128": "icons/tl-gray-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
